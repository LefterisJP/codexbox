#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------------------------------------
# codexbox: host entrypoint + subcommand dispatcher
#
# Usage:
#   codexbox [--profile name] [--tool codex|claude-code] /path/to/repo [out_dir]
#   codexbox build               # build all container images
#   codexbox remote [path/to/repo]
#   codexbox pull   [path/to/repo]
# ---------------------------------------------------------------------------

CODEXBOX_HOME="${CODEXBOX_HOME:-$HOME/.codexbox}"
BIN_DIR="$CODEXBOX_HOME/bin"

die() { echo "ERROR: $*" >&2; exit 1; }

usage() {
  cat >&2 <<'EOF'
Usage:
  codexbox [--profile name] [--tool codex|claude-code] /path/to/repo [out_dir]
  codexbox build                Build all container images
  codexbox remote [path/to/repo]
  codexbox pull   [path/to/repo]

Options:
  --profile name                Choose profile (default: rotki). Can also set CODEXBOX_PROFILE env
  --tool codex|claude-code      Choose AI tool (default: codex). Can also set CODEXBOX_TOOL env
EOF
}

# --------------------------- subcommand dispatcher --------------------------

cmd="${1:-}"

case "$cmd" in
  build)
    shift
    CONTAINERFILE="$CODEXBOX_HOME/Containerfile"
    [[ -f "$CONTAINERFILE" ]] || die "Containerfile not found at: $CONTAINERFILE"

    # Extract all final build targets from the Containerfile (skip intermediate stages
    # like 'base' and 'rotki-toolchain' that are only used as parents by other stages).
    # A stage is intermediate if another FROM references it; final targets are the rest.
    ALL_STAGES=()
    PARENT_STAGES=()
    while IFS= read -r line; do
      if [[ "$line" =~ ^FROM[[:space:]]+.*[[:space:]]AS[[:space:]]+([a-zA-Z0-9_-]+) ]]; then
        stage="${BASH_REMATCH[1]}"
        ALL_STAGES+=("$stage")
      fi
      if [[ "$line" =~ ^FROM[[:space:]]+([a-zA-Z0-9_-]+)[[:space:]]+AS ]]; then
        PARENT_STAGES+=("${BASH_REMATCH[1]}")
      fi
    done < "$CONTAINERFILE"

    TARGETS=()
    for stage in "${ALL_STAGES[@]}"; do
      is_parent=false
      for parent in "${PARENT_STAGES[@]}"; do
        if [[ "$stage" == "$parent" ]]; then
          is_parent=true
          break
        fi
      done
      if ! $is_parent; then
        TARGETS+=("$stage")
      fi
    done

    if [[ ${#TARGETS[@]} -eq 0 ]]; then
      die "No build targets found in $CONTAINERFILE"
    fi

    echo "Building all container targets:"
    for target in "${TARGETS[@]}"; do
      echo "  codexbox:$target"
    done
    echo

    for target in "${TARGETS[@]}"; do
      echo "=== Building codexbox:$target ==="
      podman build -t "codexbox:$target" -f "$CONTAINERFILE" --target "$target" "$CODEXBOX_HOME" \
        || die "Failed to build target: $target"
      echo
    done

    echo "All images built successfully."
    exit 0
    ;;
  remote)
    shift
    [[ -x "$BIN_DIR/cb-remote" ]] || die "Missing or non-executable: $BIN_DIR/cb-remote"
    exec "$BIN_DIR/cb-remote" "${1:-.}"
    ;;
  pull)
    shift
    [[ -x "$BIN_DIR/cb-pull" ]] || die "Missing or non-executable: $BIN_DIR/cb-pull"
    exec "$BIN_DIR/cb-pull" "${1:-.}"
    ;;
  ""|-h|--help|help)
    usage
    exit 0
    ;;
esac

# If we didn't match a subcommand, we treat the first arg as a repo path.
# ------------------------------ args ----------------------------------------

PROFILE_OVERRIDE=""
TOOL_OVERRIDE=""
POSITIONAL=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --profile)
      shift
      [[ $# -gt 0 ]] || die "--profile requires a value"
      PROFILE_OVERRIDE="$1"
      shift
      continue
      ;;
    --profile=*)
      PROFILE_OVERRIDE="${1#*=}"
      shift
      continue
      ;;
    --tool)
      shift
      [[ $# -gt 0 ]] || die "--tool requires a value (codex or claude-code)"
      TOOL_OVERRIDE="$1"
      shift
      continue
      ;;
    --tool=*)
      TOOL_OVERRIDE="${1#*=}"
      shift
      continue
      ;;
    --)
      shift
      POSITIONAL+=("$@")
      break
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -*)
      die "Unknown option: $1"
      ;;
    *)
      POSITIONAL+=("$1")
      shift
      continue
      ;;
  esac
done

set -- "${POSITIONAL[@]}"

if [[ $# -lt 1 ]]; then
  usage
  exit 1
fi

REPO="$(realpath "$1")"
OUT="${2:-$REPO/.codexbox-out}"
mkdir -p "$OUT"

# ------------------------------ tool selection --------------------------------

TOOL_NAME="$TOOL_OVERRIDE"
[[ -z "$TOOL_NAME" ]] && TOOL_NAME="${CODEXBOX_TOOL:-}"
TOOL_NAME="${TOOL_NAME:-codex}"

case "$TOOL_NAME" in
  codex|claude-code) ;;
  *) die "Unknown tool '$TOOL_NAME'. Supported: codex, claude-code" ;;
esac

# Capture host git identity so the container inherits it
HOST_GIT_NAME=""
if ! HOST_GIT_NAME="$(git -C "$REPO" config user.name 2>/dev/null)"; then
  HOST_GIT_NAME=""
fi
if [[ -z "$HOST_GIT_NAME" ]]; then
  if ! HOST_GIT_NAME="$(git config --global user.name 2>/dev/null)"; then
    HOST_GIT_NAME=""
  fi
fi

HOST_GIT_EMAIL=""
if ! HOST_GIT_EMAIL="$(git -C "$REPO" config user.email 2>/dev/null)"; then
  HOST_GIT_EMAIL=""
fi
if [[ -z "$HOST_GIT_EMAIL" ]]; then
  if ! HOST_GIT_EMAIL="$(git config --global user.email 2>/dev/null)"; then
    HOST_GIT_EMAIL=""
  fi
fi

# ------------------------------ host auth -----------------------------------

AUTH_IN_OUT=""

if [[ "$TOOL_NAME" == "codex" ]]; then
  HOST_CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
  HOST_AUTH="$HOST_CODEX_HOME/auth.json"
  [[ -f "$HOST_AUTH" ]] || die "Can't find auth.json at: $HOST_AUTH (run: codex login)"

  AUTH_IN_OUT="$OUT/auth.json"
  cp -f "$HOST_AUTH" "$AUTH_IN_OUT"
  chmod 600 "$AUTH_IN_OUT"
else
  # claude-code: The npm-installed version in the container reads credentials
  # from $HOME/.claude.json (note: at $HOME root, NOT inside ~/.claude/).
  # The host native binary stores OAuth tokens in ~/.claude/.credentials.json
  # and onboarding state in ~/.claude.json at $HOME root.
  #
  # We need to merge OAuth tokens into the onboarding state file so the
  # container's Claude Code finds both in $HOME/.claude.json.
  HOST_CLAUDE_HOME="${CLAUDE_HOME:-$HOME/.claude}"
  HOST_CLAUDE_STATE="$HOME/.claude.json"
  HOST_CLAUDE_CREDS="$HOST_CLAUDE_HOME/.credentials.json"

  # OAuth tokens live in ~/.claude/.credentials.json
  [[ -f "$HOST_CLAUDE_CREDS" ]] || die "Can't find Claude credentials at $HOST_CLAUDE_CREDS. Run: claude login"

  CLAUDE_STAGE_DIR="$OUT/claude-config"
  mkdir -p "$CLAUDE_STAGE_DIR"

  # Build .claude.json (onboarding state + account metadata).
  # Claude Code reads OAuth tokens from ~/.claude/.credentials.json, NOT from
  # ~/.claude.json. The state file just needs oauthAccount (account metadata)
  # and onboarding flags.
  python3 -c "
import json, sys

# Load onboarding state (has theme, hasCompletedOnboarding, etc.)
state = {}
state_file = '$HOST_CLAUDE_STATE'
try:
    with open(state_file) as f:
        state = json.load(f)
except FileNotFoundError:
    state = {}

# Ensure onboarding is marked complete
state.setdefault('hasCompletedOnboarding', True)
state.setdefault('numStartups', 1)

with open('$CLAUDE_STAGE_DIR/.claude.json', 'w') as f:
    json.dump(state, f)
" || die "Failed to build Claude state for container"

  chmod 600 "$CLAUDE_STAGE_DIR/.claude.json"

  # Stage .credentials.json (OAuth tokens with refreshToken) from the host.
  # This gets mounted at a temp path and copied into ~/.claude/ by the
  # container script (to avoid podman creating ~/.claude/ as root).
  cp -f "$HOST_CLAUDE_CREDS" "$CLAUDE_STAGE_DIR/.credentials.json"
  chmod 600 "$CLAUDE_STAGE_DIR/.credentials.json"

  # Copy settings if available
  if [[ -f "$HOST_CLAUDE_HOME/settings.json" ]]; then
    cp -f "$HOST_CLAUDE_HOME/settings.json" "$CLAUDE_STAGE_DIR/settings.json"
  fi
fi

# ------------------------- helpers to mount into container ------------------

# Container-side helper scripts are on the host here:
#   ~/.codexbox/bin/cb-export
#   ~/.codexbox/bin/cb-import
#
# We mount them directly into /usr/local/bin so PATH does not matter.
HOST_CB_EXPORT="$BIN_DIR/cb-export"
HOST_CB_IMPORT="$BIN_DIR/cb-import"

[[ -x "$HOST_CB_EXPORT" ]] || die "Missing or non-executable: $HOST_CB_EXPORT"
[[ -x "$HOST_CB_IMPORT" ]] || die "Missing or non-executable: $HOST_CB_IMPORT"

# ----------------------------- run metadata ---------------------------------

RUN_ID="$(date +%Y%m%d-%H%M%S)"
LOG="$OUT/run-$RUN_ID.log"

# --------------------------- profile config ---------------------------------

PROFILE_DIR="$CODEXBOX_HOME/profiles"

config_profile=""
CONFIG_FILE="$REPO/.codexbox/config"
if [[ -f "$CONFIG_FILE" ]]; then
  config_profile="$(awk -F '=' '
    /^[[:space:]]*#/ {next}
    /^[[:space:]]*profile[[:space:]]*=/ {
      val=$2
      sub(/#.*/, "", val)
      sub(/^[[:space:]]*/, "", val)
      sub(/[[:space:]]*$/, "", val)
      print val
      exit
    }
  ' "$CONFIG_FILE")"
fi

PROFILE_NAME="$PROFILE_OVERRIDE"
[[ -z "$PROFILE_NAME" ]] && PROFILE_NAME="${CODEXBOX_PROFILE:-}"
[[ -z "$PROFILE_NAME" ]] && PROFILE_NAME="$config_profile"
PROFILE_NAME="${PROFILE_NAME:-rotki}"

PROFILE_FILE="$PROFILE_DIR/$PROFILE_NAME.sh"
[[ -f "$PROFILE_FILE" ]] || die "Unknown profile '$PROFILE_NAME' (expected $PROFILE_FILE)"

# shellcheck source=/dev/null
source "$PROFILE_FILE"

PROFILE_IMAGE="${PROFILE_IMAGE:-}"
[[ -n "$PROFILE_IMAGE" ]] || die "Profile '$PROFILE_NAME' did not set PROFILE_IMAGE"

PROFILE_BOOTSTRAP="${PROFILE_BOOTSTRAP:-}"
[[ -n "$PROFILE_BOOTSTRAP" ]] || die "Profile '$PROFILE_NAME' did not set PROFILE_BOOTSTRAP"
[[ -x "$PROFILE_BOOTSTRAP" ]] || die "Bootstrap script not executable: $PROFILE_BOOTSTRAP"

if ! declare -p PROFILE_PODMAN_OPTS >/dev/null 2>&1; then
  PROFILE_PODMAN_OPTS=()
fi

C_PROFILE_BOOTSTRAP="/usr/local/bin/cb-profile-bootstrap"
PROFILE_PODMAN_ARGS_STR=""
for arg in "${PROFILE_PODMAN_OPTS[@]}"; do
  PROFILE_PODMAN_ARGS_STR+=" $(printf '%q' "$arg")"
done

echo "Profile:    $PROFILE_NAME"
echo "Tool:       $TOOL_NAME"
echo "Image:      $PROFILE_IMAGE"
echo "Bootstrap:  $PROFILE_BOOTSTRAP"

# --------------------------- container config -------------------------------

# Fixed container paths
C_WORKDIR="/tmp/codexworkspace"
C_CODEX_HOME="/opt/codexbox-home"
C_CLAUDE_HOME="/home/node/.claude"

if [[ "$TOOL_NAME" == "codex" ]]; then
  C_AUTH_SRC="/tmp/codex-auth/auth.json"
fi

# Pre-flight: verify the container image exists
if ! podman image exists "$PROFILE_IMAGE" 2>/dev/null; then
  die "Container image '$PROFILE_IMAGE' not found. Build it first (see Containerfile comments for build commands)."
fi

echo "Repo (host):  $REPO"
echo "Out dir:      $OUT"
echo "Log file:     $LOG"
echo

# Minimal container script: prep auth, clone, bootstrap, then run the AI tool.
# No fancy quoting tricks inside; we use a single-quoted heredoc and pass it safely.
# CODEXBOX_TOOL is passed as an env var so the script knows which tool to launch.
CONTAINER_SCRIPT="$(cat <<'EOS'
set -euo pipefail

WORKDIR="/tmp/codexworkspace"
TOOL="${CODEXBOX_TOOL:-codex}"

# Sanity: helper commands must exist
if ! command -v cb-export >/dev/null 2>&1; then
  echo "[codexbox] ERROR: cb-export not found (expected at /usr/local/bin/cb-export)"
  ls -la /usr/local/bin/cb-export /usr/local/bin/cb-import || true
  exit 1
fi

# Set up auth based on tool
if [[ "$TOOL" == "codex" ]]; then
  CODEX_HOME_DIR="/opt/codexbox-home"
  AUTH_SRC="/tmp/codex-auth/auth.json"
  mkdir -p "$CODEX_HOME_DIR"
  cp -f "$AUTH_SRC" "$CODEX_HOME_DIR/auth.json"
  chmod 600 "$CODEX_HOME_DIR/auth.json"
else
  # Set up ~/.claude directory with instructions and credentials.
  CLAUDE_HOME_DIR="$HOME/.claude"
  mkdir -p "$CLAUDE_HOME_DIR"
  if [[ -f /opt/claude-home/CLAUDE.md ]]; then
    cp -f /opt/claude-home/CLAUDE.md "$CLAUDE_HOME_DIR/CLAUDE.md"
  fi

  # Copy OAuth credentials from temp mount into the proper location.
  if [[ -f /tmp/claude-credentials.json ]]; then
    cp -f /tmp/claude-credentials.json "$CLAUDE_HOME_DIR/.credentials.json"
    chmod 600 "$CLAUDE_HOME_DIR/.credentials.json"
  fi

  # Pre-trust the workspace and mark onboarding complete in .claude.json
  # so Claude Code doesn't prompt for trust or permissions interactively.
  python3 -c "
import json
state_file = '$HOME/.claude.json'
with open(state_file) as f:
    state = json.load(f)
state.setdefault('projects', {})
state['projects']['$WORKDIR'] = {
    'hasTrustDialogAccepted': True,
    'hasCompletedProjectOnboarding': True,
    'allowedTools': [],
}
state['bypassPermissionsModeAccepted'] = True
with open(state_file, 'w') as f:
    json.dump(state, f)
"
fi

rm -rf "$WORKDIR"
mkdir -p "$WORKDIR"
git clone --no-hardlinks /src "$WORKDIR"
cd "$WORKDIR"

BOOTSTRAP_SCRIPT="${CODEXBOX_BOOTSTRAP:-/usr/local/bin/cb-profile-bootstrap}"
if [[ -x "$BOOTSTRAP_SCRIPT" ]]; then
  echo "[codexbox] Running profile bootstrap: $BOOTSTRAP_SCRIPT"
  "$BOOTSTRAP_SCRIPT"
else
  echo "[codexbox] Bootstrap script not found or not executable: $BOOTSTRAP_SCRIPT"
fi

# Shared host bridge repo for iterative sync
git init --bare /out/host.git 2>/dev/null || true
git remote add host /out/host.git 2>/dev/null || true

echo "[codexbox] Ready. Use: cb-export \"msg\" to sync to host."

if [[ "$TOOL" == "codex" ]]; then
  exec codex --dangerously-bypass-approvals-and-sandbox
else
  exec claude --dangerously-skip-permissions
fi
EOS
)"

# Build tool-specific env vars and mounts for podman
TOOL_PODMAN_ARGS=""
TOOL_PODMAN_MOUNTS=""
if [[ "$TOOL_NAME" == "codex" ]]; then
  TOOL_PODMAN_ARGS="-e CODEX_HOME=$C_CODEX_HOME"
else
  # Mount .claude.json (onboarding state) and .credentials.json (OAuth tokens with
  # refresh token) so Claude Code can manage its own token lifecycle.
  # NOTE: Do NOT set CLAUDE_CONFIG_DIR="" — the ?? operator in Claude Code treats
  # empty string as a valid value, breaking credential path resolution.
  TOOL_PODMAN_ARGS=""
  # Mount .claude.json at $HOME and .credentials.json at a temp path.
  # The container script copies credentials into ~/.claude/ after mkdir.
  TOOL_PODMAN_MOUNTS="-v $(printf '%q' "$CLAUDE_STAGE_DIR/.claude.json"):/home/node/.claude.json:Z -v $(printf '%q' "$CLAUDE_STAGE_DIR/.credentials.json"):/tmp/claude-credentials.json:ro,Z"
fi

# Keep the tool interactive while logging
script -q -f -c "
podman run --rm -it \
  --security-opt=no-new-privileges \
  --cap-drop=all \
  --userns=keep-id \
  --network slirp4netns:allow_host_loopback=false \
  $TOOL_PODMAN_ARGS \
  -e CODEXBOX_TOOL=$(printf '%q' "$TOOL_NAME") \
  -e CODEXBOX_BOOTSTRAP=$C_PROFILE_BOOTSTRAP \
  -e CODEXBOX_GIT_NAME=$(printf '%q' "$HOST_GIT_NAME") \
  -e CODEXBOX_GIT_EMAIL=$(printf '%q' "$HOST_GIT_EMAIL") \
  -v \"$REPO\":/src:ro,Z \
  -v \"$OUT\":/out:Z \
  ${AUTH_IN_OUT:+-v \"$AUTH_IN_OUT\":\"$C_AUTH_SRC\":ro,Z} \
  $TOOL_PODMAN_MOUNTS \
  -v \"$HOST_CB_EXPORT\":/usr/local/bin/cb-export:ro,Z \
  -v \"$HOST_CB_IMPORT\":/usr/local/bin/cb-import:ro,Z \
  -v \"$PROFILE_BOOTSTRAP\":\"$C_PROFILE_BOOTSTRAP\":ro,Z \
  $PROFILE_PODMAN_ARGS_STR \
  $(printf '%q' "$PROFILE_IMAGE") \
  bash -lc $(printf '%q' "$CONTAINER_SCRIPT")
" "$LOG"

echo
echo "Done."
echo "Log:   $LOG"
echo "Host bridge repo: $OUT/host.git"
